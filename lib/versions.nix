# Package Version Mapping
# =======================
# Auto-generated comprehensive version mappings for all container images.
#
# Usage:
#   let getVersion = import ./versions.nix { inherit pkgs; };
#   in getVersion "nginx"  # Returns nginx version string

{ pkgs }:

let
  # Helper to ensure version is a string
  toVersionString = v: if builtins.isString v then v else toString v;

  # Safely get version - uses tryEval to handle removed/broken packages
  getVer = attr: 
    let
      result = builtins.tryEval (
        if pkgs ? ${attr} && pkgs.${attr} ? version 
        then toVersionString pkgs.${attr}.version 
        else null
      );
    in
      if result.success then result.value else null;

